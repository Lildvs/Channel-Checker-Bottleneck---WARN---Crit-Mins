# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=channelcheck
DB_USER=channelcheck
DB_PASSWORD=your_secure_password_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API Keys - Critical (Get these first)
FRED_API_KEY=your_fred_api_key
BLS_API_KEY=your_bls_api_key
BEA_API_KEY=your_bea_api_key
EIA_API_KEY=your_eia_api_key
CENSUS_API_KEY=your_census_api_key

# API Keys - Important
USDA_NASS_API_KEY=your_usda_nass_api_key
NOAA_API_KEY=your_noaa_api_key
UN_COMTRADE_API_KEY=your_un_comtrade_api_key
OPENSECRETS_API_KEY=your_opensecrets_api_key

# SEC EDGAR (required per SEC policy - use company name + email)
SEC_USER_AGENT=YourCompany contact@example.com

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development

# LLM API Keys (at least one required for LLM-powered forecasting)
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# Forecasting Settings
FORECASTING_USE_LLM=true
FORECASTING_DEFAULT_MODEL=gpt-5
FORECASTING_MAX_COST_PER_FORECAST=3.50
